# PATH: .env.example
#
# Only these variables are required. Everything else
# (site name, toggles, banner text, etc.) is configured
# inside the Admin → Settings panel and stored in the database.

# ── Required ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-strong-password
JWT_SECRET=generate-with--openssl-rand-hex-32
API_SECRET_KEY=generate-with--openssl-rand-hex-32

# ── Optional ───────────────────────────────────────────────────────
# Public URL of your deployment (used for SSR links)
NUXT_PUBLIC_SITE_URL=https://your-domain.com
