# ── Neon Postgres ─────────────────────────────────────────────────
# Copy from your Neon dashboard → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Admin credentials ──────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-strong-password

# ── JWT secret ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your-random-64-char-hex-string

# ── External API key ───────────────────────────────────────────────
# Used by other projects to push updates via POST /api/v1/projects
# Generate with: openssl rand -hex 32
API_SECRET_KEY=another-random-64-char-hex-string

# ── Site identity (public — visible in the browser) ────────────────
NUXT_PUBLIC_SITE_URL=https://your-domain.com

# Display name shown in the footer, hero sub-header, etc.
# Default: Developer
NUXT_PUBLIC_SITE_OWNER=Developer

# Top-bar brand label (the part before the domain suffix)
# Default: repository
NUXT_PUBLIC_TOPBAR_TITLE=repository

# Optional domain suffix shown in the top-bar (e.g. .your-domain.com)
# Leave blank to show nothing after the title
NUXT_PUBLIC_TOPBAR_DOMAIN=

# Hero headline — the large text on the index page
# Default: Everything I've built.
NUXT_PUBLIC_HERO_BANNER=Everything I've built.

# Hero sub-text below the headline
NUXT_PUBLIC_HERO_SUB=A living catalogue of side projects, tools, and experiments.

# ── Origin / fork UI ───────────────────────────────────────────────
# Set to "true" to hide the "Want your own repository page? Fork here" button
# Useful when deploying as your own instance
NUXT_PUBLIC_HIDE_ORIGIN_UI=false

# URL that the fork button links to
NUXT_PUBLIC_FORK_URL=https://github.com/surelle-ha/repository
